# BidWar — Environment Variables Reference
# Copy to .env and fill in real values. Never commit .env to source control.
# Set production values in your host dashboard (Render, Railway, VPS, etc.).

# ── Required (API server exits at startup if missing) ─────────────────────────

# production | development | test
NODE_ENV=production

# TCP port the Node process listens on (Render injects this automatically)
PORT=3000

# PostgreSQL connection string (NEON_DATABASE_URL takes priority when both are set)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Comma-separated hostnames only — no https:// (first entry is canonical)
# Production: APP_DOMAIN=bidwar.in,www.bidwar.in
# Local dev:   APP_DOMAIN=localhost
APP_DOMAIN=bidwar.in

# Public URL scheme for links, OAuth callbacks, and SMS (http or https)
# Must be https in production
APP_PUBLIC_SCHEME=https

# Session signing secret — minimum 32 characters
# Generate: openssl rand -hex 32
SESSION_SECRET=replace-with-32-byte-random-hex-minimum-32-chars

# Super-admin password
ADMIN_PASSWORD=replace-with-strong-password

# When true, API serves pre-built auction-platform + owner-app static files
SERVE_STATIC=true

# ── Optional — server / CORS ──────────────────────────────────────────────────

# Second admin password restricted to data-export operations only
# ADMIN_DATA_PASSWORD=replace-with-export-only-password

# Explicit CORS origins (comma-separated full URLs)
# If omitted, built from APP_DOMAIN + APP_PUBLIC_SCHEME
# CORS_ORIGINS=https://bidwar.in,https://www.bidwar.in

# Development only: extra non-loopback origins (LAN IP, tunnel URL, etc.)
# EXTRA_CORS_ORIGINS=http://192.168.1.10:3000

# Log verbosity: fatal | error | warn | info | debug | trace (default: info)
# LOG_LEVEL=info

# ── Optional — local split dev (pnpm dev) ─────────────────────────────────────
# Do not use PORT alone for split dev — API and Vite run on separate ports.

# API_PORT=8080
# FRONTEND_PORT=3000
# WEB_PORT=3000
# OWNER_APP_PORT=5174
# BASE_PATH=/

# Vite proxies /api → API_DEV_PROXY_TARGET (REST, SSE, uploads, OAuth)
# API_DEV_PROXY_TARGET=http://127.0.0.1:8080
# VITE_DEV_API_TARGET=http://127.0.0.1:8080

# Owner-app dev proxy target (when proxied through auction-platform)
# OWNER_APP_DEV_PROXY_TARGET=http://127.0.0.1:5174
# VITE_DEV_OWNER_APP_TARGET=http://127.0.0.1:5174

# Smoke-test URLs (pnpm run verify:local)
# VERIFY_API_URL=http://127.0.0.1:8080
# VERIFY_FRONTEND_URL=http://127.0.0.1:3000
# VERIFY_OWNER_APP_URL=http://127.0.0.1:5174

# Production smoke test (pnpm run verify:production)
# VERIFY_BASE_URL=https://bidwar.in

# ── Optional — Cloudinary (image uploads) ─────────────────────────────────────
# Without these, upload routes return 503

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Must start with cloudinary:// if set — invalid values are deleted at startup
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── Optional — Google OAuth (organizer login) ─────────────────────────────────
# Redirect URI: {APP_PUBLIC_SCHEME}://{canonical-host}/api/auth/google/callback

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Optional — Web Push / VAPID (owner-app push notifications) ────────────────
# Generate: npx web-push generate-vapid-keys

VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ── Optional — BulkSMS / DLT SMS ──────────────────────────────────────────────
# BULKSMS_KEY and BULKSMS_PASSWORD are interchangeable (BULKSMS_KEY preferred)

BULKSMS_KEY=your-fast2sms-api-key
# BULKSMS_PASSWORD=your-fast2sms-api-key
BULKSMS_SENDER=BIDWRR
BULKSMS_TEMPLATE_ID=your-otp-template-id
BULKSMS_PLAYER_SOLD_TEMPLATE_ID=your-template-id
BULKSMS_TEAM_OWNER_TEMPLATE_ID=your-template-id
BULKSMS_VIEWER_LINK_TEMPLATE_ID=your-template-id

# ── Optional — Twilio (WhatsApp + webhook signature verification) ─────────────

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Comma-separated approved WhatsApp template names
# TWILIO_WA_TEMPLATES=template_one,template_two

# ── Optional — SMS OTP mode (BulkSMS instead of Twilio Verify) ────────────────

# SMS_OTP_ENABLED=true

# ── Optional — GitHub PAT (settings → trigger workflow deploy) ────────────────

# GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional — rate limiting ──────────────────────────────────────────────────

RATE_LIMIT_DISABLED=false
RATE_LIMIT_GLOBAL_MAX=2500
RATE_LIMIT_AUTH_MAX=100
RATE_LIMIT_OTP_SEND_MAX=3
RATE_LIMIT_OTP_VERIFY_MAX=10
RATE_LIMIT_EXPORT_MAX=5
RATE_LIMIT_CHEER_MAX=30
RATE_LIMIT_PUSH_SUBSCRIBE_MAX=5
RATE_LIMIT_OWNER_LOOKUP_MAX=15

# Optional — Cloudflare Turnstile for organizer login CAPTCHA (attempts 6–10)
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# ── Development only (never in production) ────────────────────────────────────

# Skip OTP verification in dev (startup fails if true in production)
# BYPASS_OTP=true

# ── bidwar-local (Electron desktop app only) ──────────────────────────────────

# DB_PATH=./auction.db
# CLOUD_BASE_URL=https://your-cloud-api.example.com
