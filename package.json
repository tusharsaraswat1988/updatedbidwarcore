{
  "name": "workspace",
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');for (const f of ['package-lock.json','yarn.lock']) { try { fs.unlinkSync(f); } catch {} }\"",
    "dev": "pnpm --filter @workspace/scripts run dev",
    "dev:stop": "pnpm --filter @workspace/scripts run dev:stop",
    "dev:restart": "pnpm dev:stop && pnpm dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "build:prod": "pnpm install --frozen-lockfile --prod=false && pnpm run build",
    "start:prod": "cross-env NODE_ENV=production SERVE_STATIC=true node --enable-source-maps artifacts/api-server/dist/index.mjs",
    "db:push:prod": "cross-env NODE_ENV=production pnpm --filter @workspace/db run push",
    "migrate:prod": "cross-env NODE_ENV=production pnpm --filter @workspace/scripts run migrate",
    "db:setup:prod": "pnpm run db:push:prod && pnpm run migrate:prod",
    "verify:local": "pnpm --filter @workspace/scripts run verify:local",
    "verify:production": "pnpm --filter @workspace/scripts run verify:production"
  },
  "private": true,
  "devDependencies": {
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.9",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "drizzle-orm": "catalog:"
  }
}
