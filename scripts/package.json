{
  "name": "@workspace/scripts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "hello": "tsx ./src/hello.ts",
    "seed:demo": "tsx --env-file=../.env src/seed-demo.ts",
    "seed:scoring-local": "tsx --env-file=../.env src/seed-scoring-local.ts",
    "seed:sports": "tsx src/seed-sports.ts",
    "purge:badminton-matches": "tsx --env-file=../.env src/purge-badminton-matches.ts",
    "migrate": "tsx src/migrate.ts",
    "dev": "node ./dev.mjs",
    "dev:stop": "node ./dev-stop.mjs",
    "verify:local": "tsx src/verify-local.ts",
    "verify:production": "tsx src/verify-production.ts",
    "setup:playwright-browsers": "node ./setup-playwright-browsers.mjs",
    "verify:root-cause-rcv": "tsx --env-file=../.env src/verify-root-cause-rcv.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/pg": "^8.18.0",
    "@workspace/api-base": "workspace:*",
    "@workspace/badminton-core": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/scoring-core": "workspace:*",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:"
  }
}
