# BidWar — Environment Variables Reference
# Copy to .env and fill in real values. Never commit .env to source control.
# On Replit, set these as Secrets. On Railway/Render/DO, set as env vars in the dashboard.

# ── Database ──────────────────────────────────────────────────────────────────
# Either NEON_DATABASE_URL or DATABASE_URL is accepted (NEON_DATABASE_URL takes priority).
# Use DATABASE_URL on Railway, Render, DigitalOcean, VPS, and other standard hosts.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ── Application domain ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# The FIRST entry is used as the canonical domain for OAuth redirect URIs,
# SMS/WhatsApp links, and push notification URLs.
# Example: APP_DOMAIN=bidwar.in,www.bidwar.in
APP_DOMAIN=bidwar.in

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# When true, the API server also serves the pre-built Vite frontends on the
# same port — no separate nginx or Vite dev server needed.
# Set to true for Railway, Render, Docker, VPS, and Hostinger.
SERVE_STATIC=true

# ── Session / Auth ────────────────────────────────────────────────────────────
# Required in production. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-32-byte-random-hex

# ── Admin ─────────────────────────────────────────────────────────────────────
# Main super-admin password (full access)
ADMIN_PASSWORD=replace-with-strong-password
# Optional second admin password restricted to data-export operations only
# ADMIN_DATA_PASSWORD=replace-with-export-only-password

# ── Cloudinary (image uploads) ────────────────────────────────────────────────
# From https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Optional: if set, must start with "cloudinary://" — otherwise it is deleted automatically
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── Google OAuth (optional — organizer login) ─────────────────────────────────
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Web Push / VAPID (owner-app push notifications) ──────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ── BulkSMS / DLT SMS ─────────────────────────────────────────────────────────
# BULKSMS_KEY is the preferred env var name; BULKSMS_PASSWORD is an accepted alias
BULKSMS_KEY=your-fast2sms-api-key
# BULKSMS_PASSWORD=your-fast2sms-api-key   (alias — use one or the other)
# Sender ID exactly as registered on Fast2SMS DLT (e.g. BIDWRR — 6 chars, no spaces)
BULKSMS_SENDER=BIDWRR
# OTP template ID (used for organizer/owner login OTP)
BULKSMS_TEMPLATE_ID=your-otp-template-id
# Per-notification DLT template IDs — set these to avoid entering them in the admin panel.
# Env var takes priority over any value stored in the database.
BULKSMS_PLAYER_SOLD_TEMPLATE_ID=215964
# BULKSMS_TEAM_OWNER_TEMPLATE_ID=your-team-owner-template-id
# BULKSMS_VIEWER_LINK_TEMPLATE_ID=your-viewer-link-template-id

# ── Twilio (OTP verification + optional WhatsApp) ─────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WhatsApp sender number (e.g. "whatsapp:+14155238886") — required for WA messaging
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Comma-separated WhatsApp template names pre-approved on your Twilio account
# TWILIO_WA_TEMPLATES=player_sold_alert,team_welcome

# ── GitHub (optional — update checks in settings) ─────────────────────────────
# Personal Access Token with read:repo scope — used to fetch the latest release tag
# GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Rate limiting (optional — defaults shown) ─────────────────────────────────
# Set RATE_LIMIT_DISABLED=true to turn off all rate limiting (dev/testing only)
RATE_LIMIT_DISABLED=false
# Global catch-all: requests per 15 min per IP (auction routes always exempt)
RATE_LIMIT_GLOBAL_MAX=1000
# Login brute-force: attempts per 15 min per IP
RATE_LIMIT_AUTH_MAX=5
# OTP send: requests per 5 min per IP (each send = a paid SMS)
RATE_LIMIT_OTP_SEND_MAX=3
# OTP verify: attempts per 15 min per IP
RATE_LIMIT_OTP_VERIFY_MAX=10
# Export: full tournament snapshot requests per 15 min per IP
RATE_LIMIT_EXPORT_MAX=5
# Cheer: audience cheer requests per min per IP
RATE_LIMIT_CHEER_MAX=30
# Web push subscription: subscribe requests per 15 min per IP
RATE_LIMIT_PUSH_SUBSCRIBE_MAX=5

# ── Development / debugging ───────────────────────────────────────────────────
# BYPASS_OTP=true          — skip Twilio OTP check (dev only)
# SMS_OTP_ENABLED=false    — disable OTP SMS sending entirely
# LOG_LEVEL=debug          — pino log level (trace/debug/info/warn/error)
