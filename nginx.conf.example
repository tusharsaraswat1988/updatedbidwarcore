# BidWar — nginx reverse-proxy configuration example
#
# Copy to /etc/nginx/sites-available/bidwar and symlink to sites-enabled.
# Replace YOUR_DOMAIN with your actual domain (e.g. bidwar.in).
# The Node.js app must be running on port 3000 with SERVE_STATIC=true.
#
# After editing, test with:   nginx -t
# Reload config with:         systemctl reload nginx

upstream bidwar_app {
    server 127.0.0.1:3000;
    keepalive 64;
}

# Redirect HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name YOUR_DOMAIN www.YOUR_DOMAIN;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name YOUR_DOMAIN www.YOUR_DOMAIN;

    # ── TLS (Let's Encrypt via certbot) ───────────────────────────────────────
    ssl_certificate     /etc/letsencrypt/live/YOUR_DOMAIN/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;

    # ── Security headers ──────────────────────────────────────────────────────
    add_header X-Frame-Options SAMEORIGIN;
    add_header X-Content-Type-Options nosniff;
    add_header Referrer-Policy strict-origin-when-cross-origin;

    # ── Gzip (nginx-level, for clients that don't accept br) ──────────────────
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml;
    gzip_min_length 1024;
    gzip_vary on;

    # ── SSE (Server-Sent Events) — auction live updates ───────────────────────
    # Must come BEFORE the general /api location block.
    # SSE requires: no buffering, no caching, long read timeout.
    # The Node app sends a heartbeat every 20 s — proxy timeout set to 1 hour.
    location ~ ^/api/tournaments/[0-9]+/auction/events$ {
        proxy_pass         http://bidwar_app;
        proxy_http_version 1.1;

        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Connection        "";

        proxy_buffering        off;
        proxy_cache            off;
        proxy_read_timeout     3600s;
        proxy_connect_timeout  10s;
        proxy_send_timeout     3600s;

        add_header Cache-Control      "no-cache, no-store, must-revalidate";
        add_header X-Accel-Buffering  "no";
        chunked_transfer_encoding     on;
    }

    # ── API ───────────────────────────────────────────────────────────────────
    location /api/ {
        proxy_pass         http://bidwar_app;
        proxy_http_version 1.1;

        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Connection        "";

        proxy_buffering    on;
        proxy_read_timeout 60s;

        client_max_body_size 10m;
    }

    # ── Static assets (served directly by Node with immutable cache headers) ──
    # nginx just proxies — the app sets Cache-Control: max-age=31536000,immutable
    # for hashed assets and no-cache for index.html / manifests.
    location / {
        proxy_pass         http://bidwar_app;
        proxy_http_version 1.1;

        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        $connection_upgrade;

        proxy_buffering    on;
        proxy_read_timeout 30s;
    }
}

# Required for the Connection header upgrade map above
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}
