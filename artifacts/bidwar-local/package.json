{
  "name": "@workspace/bidwar-local",
  "version": "1.0.0",
  "description": "BidWar Local — offline Electron auction app",
  "author": "BidWar",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/tusharsaraswat1988/updatedbidwarcore.git"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "electron .",
    "build:icons": "node ./scripts/generate-icons.mjs",
    "build:frontend": "node ./scripts/copy-frontend.mjs",
    "build:server": "node ./build-server.mjs",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "pnpm run build:icons && pnpm run build:frontend && pnpm run build:server && pnpm run build:electron",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package:win": "electron-builder --win --publish never",
    "package:win:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win dir",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux AppImage"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@workspace/db-local": "workspace:*",
    "cors": "^2.8.5",
    "drizzle-orm": "catalog:",
    "express": "^5.1.0",
    "qrcode": "^1.5.4",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.3",
    "@types/node": "catalog:",
    "@types/qrcode": "^1.5.6",
    "electron": "^36.3.2",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.0"
  },
  "build": {
    "appId": "com.bidwar.local",
    "productName": "BidWar Local",
    "copyright": "Copyright 2025 BidWar",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**",
      "dist-server/**",
      "frontend-dist/**",
      "renderer/**",
      "node_modules/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.sports"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Sports"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": null
  }
}
