modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["sh", "-c", "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers node scripts/setup-playwright-browsers.mjs && pnpm store prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 6800

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 8084
externalPort = 3001

[[ports]]
localPort = 8085
externalPort = 4200

[[ports]]
localPort = 18732
externalPort = 5000

[[ports]]
localPort = 24755
externalPort = 3000

[[ports]]
localPort = 29999
externalPort = 6000

[userenv]

[userenv.production]
APP_DOMAIN = "bidwar.in"
APP_PUBLIC_SCHEME = "https"
CREATIVE_RENDER_WORKER_ENABLED = "true"
PLAYWRIGHT_BROWSERS_PATH = ".playwright-browsers"

[nix]
channel = "stable-25_05"
packages = ["zip"]
