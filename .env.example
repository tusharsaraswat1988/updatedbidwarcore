# BidWar — Environment Variables Reference
# Copy to .env and fill in real values. Never commit .env to source control.
# On Replit, Railway, Render, Docker, or VPS: set these in the platform dashboard or Secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# Either NEON_DATABASE_URL or DATABASE_URL is accepted (NEON_DATABASE_URL takes priority).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ── Application domain (required) ─────────────────────────────────────────────
# Comma-separated hostnames only (no https://). First entry is the canonical host.
# Production example: APP_DOMAIN=bidwar.in,www.bidwar.in
# Local dev example:  APP_DOMAIN=localhost
APP_DOMAIN=bidwar.in

# Public URL scheme for links, OAuth callbacks, and SMS (http or https).
# Must be https in production. Use http for local development.
APP_PUBLIC_SCHEME=https

# Optional: explicit CORS origins (comma-separated full URLs, e.g. https://bidwar.in).
# If omitted, origins are built from APP_DOMAIN + APP_PUBLIC_SCHEME.
# CORS_ORIGINS=https://bidwar.in,https://www.bidwar.in

# Development only: extra non-loopback origins (LAN IP, tunnel URL, etc.).
# When NODE_ENV=development, any http://localhost:* and http://127.0.0.1:* is allowed (any Vite port).
# EXTRA_CORS_ORIGINS=http://192.168.1.10:3000

# ── Server (required) ─────────────────────────────────────────────────────────
# Production / single-process: PORT=3000 (API + static UI on one port)
PORT=3000
NODE_ENV=production

# Split local dev (pnpm dev): API and Vite use separate ports — set these instead of PORT alone
# API_PORT=8080
# FRONTEND_PORT=3000
# OWNER_APP_PORT=5174

# When true, the API server also serves the pre-built Vite frontends on the same port.
SERVE_STATIC=true

# ── Local split dev (API + Vite — do not edit code between environments) ─────
# Typical Windows / Replit split setup:
#   API:       PORT=8080  NODE_ENV=development  SERVE_STATIC=false
#   Frontend:  pnpm --filter @workspace/auction-platform run dev  (port 3000)
# Vite proxies /api → API_DEV_PROXY_TARGET (all REST, SSE, uploads, OAuth).
# API_DEV_PROXY_TARGET=http://127.0.0.1:8080
# VERIFY_API_URL=http://127.0.0.1:8080
# VERIFY_FRONTEND_URL=http://127.0.0.1:3000

# ── Session / Auth (required) ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-32-byte-random-hex-minimum-32-chars

# ── Admin (required) ────────────────────────────────────────────────────────────
ADMIN_PASSWORD=replace-with-strong-password
# Optional second admin password restricted to data-export operations only
# ADMIN_DATA_PASSWORD=replace-with-export-only-password

# ── Cloudinary (image uploads) ────────────────────────────────────────────────
# From https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Optional: if set, must start with "cloudinary://" — otherwise it is deleted automatically
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── Google OAuth (optional — organizer login) ─────────────────────────────────
# Authorized redirect URI: {APP_PUBLIC_SCHEME}://{canonical-host}/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Web Push / VAPID (owner-app push notifications) ──────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ── BulkSMS / DLT SMS ─────────────────────────────────────────────────────────
BULKSMS_KEY=your-fast2sms-api-key
# BULKSMS_PASSWORD=your-fast2sms-api-key
BULKSMS_SENDER=BIDWRR
BULKSMS_TEMPLATE_ID=your-otp-template-id
BULKSMS_PLAYER_SOLD_TEMPLATE_ID=your-template-id

# ── Twilio (OTP verification + optional WhatsApp) ─────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Rate limiting (optional) ──────────────────────────────────────────────────
RATE_LIMIT_DISABLED=false
RATE_LIMIT_GLOBAL_MAX=1000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_OTP_SEND_MAX=3
RATE_LIMIT_OTP_VERIFY_MAX=10
RATE_LIMIT_EXPORT_MAX=5
RATE_LIMIT_CHEER_MAX=30
RATE_LIMIT_PUSH_SUBSCRIBE_MAX=5

# ── Development only (never in production) ────────────────────────────────────
# BYPASS_OTP=true
# LOG_LEVEL=debug
