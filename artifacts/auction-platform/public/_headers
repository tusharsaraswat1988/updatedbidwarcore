# Cache headers for static assets served in production.
# Vite builds JS/CSS with content hashes in filenames → safe to cache forever.
# HTML must never be cached so new deploys are picked up immediately.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=2592000

/*.jpg
  Cache-Control: public, max-age=2592000

/*.webp
  Cache-Control: public, max-age=2592000

/*.svg
  Cache-Control: public, max-age=2592000

/index.html
  Cache-Control: no-cache

/*.html
  Cache-Control: no-cache
