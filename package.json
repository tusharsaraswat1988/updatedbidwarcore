{
  "name": "workspace",
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "build:prod": "pnpm install --frozen-lockfile && pnpm run build",
    "start:prod": "NODE_ENV=production SERVE_STATIC=true node --enable-source-maps artifacts/api-server/dist/index.mjs"
  },
  "private": true,
  "devDependencies": {
    "drizzle-kit": "^0.31.9",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "drizzle-orm": "catalog:"
  }
}
