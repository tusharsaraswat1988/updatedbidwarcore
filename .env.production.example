# BidWar — Production environment (local `pnpm start:prod` and schema tooling)
# Copy to `.env.production` and fill in real values. Never commit `.env.production`.
# On Render/Replit/Railway, set these in the host dashboard instead of using this file.

NODE_ENV=production
BIDWAR_ENV=production
SERVE_STATIC=true
PORT=3000

# Production PostgreSQL — must be a separate database from development (.env)
DATABASE_URL=postgresql://user:password@host/production-db?sslmode=require

APP_DOMAIN=bidwar.in,www.bidwar.in
APP_URL=https://bidwar.in
APP_PUBLIC_SCHEME=https

SESSION_SECRET=replace-with-32-byte-random-hex-minimum-32-chars
ADMIN_PASSWORD=replace-with-strong-password

# Platform scoring — cricket, badminton, and future sport scoring modules
SCORING=true

# Optional — copy from .env when testing production locally with integrations enabled
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Buzz Studio creative PNG export (Media Center → Generate Creative)
CREATIVE_RENDER_WORKER_ENABLED=true
# Browser cache path — install via: pnpm run setup:playwright-browsers
PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers
# CREATIVE_RENDER_STORAGE=local
# CREATIVE_RENDER_LOCAL_DIR=./data/creative-renders
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# BULKSMS_KEY=
# BULKSMS_SENDER=
# BULKSMS_TEMPLATE_ID=

# Multi-sport (ON by default — set false only to opt out)
# PLAYER_SPECS_V2_ENABLED=true
# PLAYER_SPORT_PROFILES_ENABLED=true
